---
const skills = [
  {
    category: "Frontend",
    icon: "🎨",
    color: "from-primary to-blue-500",
    border: "border-primary/30 hover:border-primary/60",
    items: [
      { name: "React.js", level: 95 },
      { name: "Next.js", level: 90 },
      { name: "TypeScript", level: 75 },
      { name: "Tailwind CSS", level: 85 },
    ]
  },
  {
    category: "Backend",
    icon: "⚙️",
    color: "from-secondary to-purple-500",
    border: "border-secondary/30 hover:border-secondary/60",
    items: [
      { name: "Node.js", level: 90 },
      { name: "Express.js", level: 90 },
      { name: "GraphQL", level: 80 },
      { name: "Symfony / PHP", level: 75 },
    ]
  },
  {
    category: "Databases",
    icon: "🗄️",
    color: "from-accent to-cyan-500",
    border: "border-accent/30 hover:border-accent/60",
    items: [
      { name: "MongoDB", level: 85 },
      { name: "Apollo Server", level: 80 },
      { name: "MySQL / SQL", level: 70 },
    ]
  },
  {
    category: "Tools & CMS",
    icon: "🛠️",
    color: "from-green-400 to-emerald-500",
    border: "border-green-400/30 hover:border-green-400/60",
    items: [
      { name: "Git / GitHub", level: 90 },
      { name: "Prestashop", level: 75 },
      { name: "OpenCart", level: 70 },
      { name: "CodeIgniter", level: 65 },
    ]
  },
];
---

<section id="skills" class="py-24 px-6 bg-surface/30 relative">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="font-mono text-primary text-sm tracking-widest uppercase">02. Skills</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-2 text-white">Tech Stack</h2>
      <p class="text-slate-400 mt-3 max-w-xl mx-auto">The technologies I use daily to build robust and performant products.</p>
    </div>

    <!-- Tech pills (main techs) -->
    <div class="flex flex-wrap justify-center gap-3 mb-16 reveal">
      {['React.js', 'Next.js', 'Node.js', 'Express.js', 'GraphQL', 'MongoDB', 'TypeScript', 'Symfony', 'Tailwind CSS', 'Apollo Server'].map(tech => (
        <span class="px-4 py-2 rounded-full bg-card border border-slate-700 text-slate-300 text-sm font-mono hover:border-primary hover:text-primary hover:bg-primary/10 transition-all duration-300 cursor-default">
          {tech}
        </span>
      ))}
    </div>

    <!-- Skill cards with progress bars -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {skills.map((group) => (
        <div class={`bg-card rounded-2xl border ${group.border} p-6 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 reveal`}>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">{group.icon}</span>
            <h3 class={`font-bold text-white bg-gradient-to-r ${group.color} bg-clip-text text-transparent`}>
              {group.category}
            </h3>
          </div>
          <div class="space-y-4">
            {group.items.map((skill) => (
              <div>
                <div class="flex justify-between items-center mb-1.5">
                  <span class="text-slate-300 text-sm font-medium">{skill.name}</span>
                  <span class="text-slate-500 text-xs font-mono">{skill.level}%</span>
                </div>
                <div class="h-1.5 bg-slate-800 rounded-full overflow-hidden">
                  <div
                    class={`h-full rounded-full bg-gradient-to-r ${group.color} skill-bar`}
                    data-width={skill.level}
                    style="width: 0%"
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Languages -->
    <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center reveal">
      <div class="flex items-center gap-3 bg-card border border-slate-800 rounded-xl px-6 py-4">
        <span class="text-2xl">🇲🇬</span>
        <div>
          <div class="text-white font-semibold">Malagasy</div>
          <div class="text-slate-500 text-sm">Native language</div>
        </div>
      </div>
      <div class="flex items-center gap-3 bg-card border border-slate-800 rounded-xl px-6 py-4">
        <span class="text-2xl">🇫🇷</span>
        <div>
          <div class="text-white font-semibold">French</div>
          <div class="text-slate-500 text-sm">Professional level</div>
        </div>
      </div>
      <div class="flex items-center gap-3 bg-card border border-slate-800 rounded-xl px-6 py-4">
        <span class="text-2xl">🇬🇧</span>
        <div>
          <div class="text-white font-semibold">English</div>
          <div class="text-slate-500 text-sm">Elementary level</div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Animate skill bars when in viewport
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bars = entry.target.querySelectorAll('.skill-bar');
        bars.forEach((bar: Element) => {
          const htmlBar = bar as HTMLElement;
          const width = htmlBar.dataset.width + '%';
          setTimeout(() => {
            htmlBar.style.width = width;
            htmlBar.style.transition = 'width 1s ease';
          }, 200);
        });
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.bg-card').forEach(card => observer.observe(card));
</script>
