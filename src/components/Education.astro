---
const diplomas = [
  {
    degree: "Master's Degree (M2)",
    field: "Electronics, Computer Systems & Artificial Intelligence",
    school: "Institut Supérieur Polytechnique de Madagascar (ISPM)",
    location: "Antananarivo, Madagascar",
    period: "2019 — 2021",
    color: "from-primary to-secondary",
    icon: "🎓",
    skills: ["Artificial Intelligence", "Embedded Systems", "Advanced Algorithms", "Networks", "Software Development"],
  },
  {
    degree: "Bachelor's Degree",
    field: "Electronics, Computer Systems & Artificial Intelligence",
    school: "Institut Supérieur Polytechnique de Madagascar (ISPM)",
    location: "Antananarivo, Madagascar",
    period: "2016 — 2019",
    color: "from-secondary to-accent",
    icon: "📖",
    skills: ["Algorithms", "Web Development", "Databases", "PHP", "Java", "Networks"],
  },
  {
    degree: "Baccalaureate",
    field: "Series C",
    school: "Lycée Le Petit Nid",
    location: "Antananarivo, Madagascar",
    period: "2015",
    color: "from-accent to-green-400",
    icon: "🏫",
    skills: ["Mathematics", "Physics", "Sciences"],
  },
];
---

<section id="education" class="py-24 px-6 bg-surface/30 relative">
  <div class="max-w-4xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="font-mono text-primary text-sm tracking-widest uppercase">04. Education</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-2 text-white">Academic Background</h2>
    </div>

    <!-- Diploma cards -->
    <div class="space-y-6">
      {diplomas.map((d) => (
        <div class="reveal">
          <div class="bg-card border border-slate-800 rounded-2xl p-8 hover:border-slate-600 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col md:flex-row items-start gap-6">
            <!-- Icon -->
            <div class="flex-shrink-0">
              <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${d.color} flex items-center justify-center text-2xl shadow-lg`}>
                {d.icon}
              </div>
            </div>

            <!-- Content -->
            <div class="flex-1">
              <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
                <div>
                  <h3 class="text-lg font-bold text-white">{d.degree}</h3>
                  <div class={`font-semibold text-sm bg-gradient-to-r ${d.color} bg-clip-text text-transparent mt-0.5`}>{d.field}</div>
                  <div class="text-slate-400 text-sm mt-1">{d.school}</div>
                  <div class="flex items-center gap-1 text-slate-600 text-xs mt-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    {d.location}
                  </div>
                </div>
                <span class="font-mono text-sm text-slate-500 bg-slate-800 px-3 py-1.5 rounded-lg border border-slate-700 flex-shrink-0">
                  {d.period}
                </span>
              </div>

              <div class="flex flex-wrap gap-2 mt-3">
                {d.skills.map(skill => (
                  <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-slate-800 text-slate-400 border border-slate-700/50">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Self-learning section -->
    <div class="mt-8 reveal">
      <div class="bg-card border border-slate-800 rounded-2xl p-8 hover:border-secondary/40 transition-all duration-300">
        <div class="flex items-start gap-6">
          <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-gradient-to-br from-secondary to-accent flex items-center justify-center text-2xl">
            📚
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-2">Continuous Learning</h3>
            <p class="text-slate-400 text-sm leading-relaxed">
              Always keeping up with the latest tech, I regularly train through platforms like
              Udemy, YouTube, and the official documentation of the frameworks and libraries I use.
            </p>
            <div class="flex flex-wrap gap-2 mt-4">
              {['GraphQL', 'Apollo Server', 'TypeScript', 'Docker', 'CI/CD'].map(tech => (
                <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-primary/10 text-primary border border-primary/20">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
