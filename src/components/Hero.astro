---
---
<section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden px-6">
  <!-- Background gradient blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-primary/20 rounded-full blur-3xl animate-float"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-secondary/20 rounded-full blur-3xl animate-float" style="animation-delay: 3s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-3xl"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.03)_1px,transparent_1px)] bg-[size:50px_50px]"></div>
  </div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-primary/30 bg-primary/10 text-primary text-sm font-mono mb-8 animate-fade-in">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      Available for new projects
    </div>

    <!-- Name -->
    <h1 class="text-5xl md:text-7xl font-extrabold mb-4 leading-tight animate-slide-up">
      <span class="text-white">Rakotonarivo</span>
      <br />
      <span class="bg-gradient-to-r from-primary via-secondary to-accent bg-clip-text text-transparent">
        Miandrisoa Sandratra
      </span>
    </h1>

    <!-- Title -->
    <div class="font-mono text-accent text-lg md:text-xl mb-6 animate-slide-up" style="animation-delay: 0.1s;">
      <span id="typed-title">Frontend Expert & AI-Driven Developer</span>
    </div>

    <!-- Description -->
    <p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed animate-slide-up" style="animation-delay: 0.2s;">
      Specialized in <span class="text-primary font-medium">React</span>, <span class="text-secondary font-medium">Next.js</span> & <span class="text-accent font-medium">Node.js</span>.
      I build modern, high-performance web applications and leverage <span class="text-primary font-medium">AI tools</span> to ship faster and smarter.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-slide-up" style="animation-delay: 0.3s;">
      <a
        href="#experience"
        class="px-8 py-4 bg-gradient-to-r from-primary to-secondary rounded-xl font-semibold text-white hover:shadow-lg hover:shadow-primary/25 hover:scale-105 transition-all duration-300"
      >
        View my work
      </a>
      <a
        href="#contact"
        class="px-8 py-4 border border-slate-600 rounded-xl font-semibold text-slate-300 hover:border-primary hover:text-primary hover:bg-primary/5 transition-all duration-300"
      >
        Get in touch
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-20 flex flex-col items-center gap-2 text-slate-500 text-sm animate-fade-in" style="animation-delay: 0.8s;">
      <span>Scroll</span>
      <div class="w-0.5 h-12 bg-gradient-to-b from-slate-500 to-transparent animate-pulse"></div>
    </div>
  </div>
</section>
