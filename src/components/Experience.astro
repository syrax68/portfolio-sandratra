---

<section id="experience" class="py-24 px-6 relative">
  <div class="max-w-4xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="font-mono text-primary text-sm tracking-widest uppercase">03. Experience</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-2 text-white">Professional Journey</h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary via-secondary to-accent opacity-30 md:-translate-x-0.5"></div>

      <div class="space-y-10">
        {experiences.map((exp, i) => (
          <div class={`relative flex items-start gap-6 md:gap-0 reveal ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- Dot -->
            <div class="relative z-10 flex-shrink-0 md:absolute md:left-1/2 md:-translate-x-1/2 md:top-6">
              <div class={`w-4 h-4 rounded-full ${exp.dot} ring-4 ring-dark shadow-lg`}>
                {exp.current && <div class="absolute inset-0 rounded-full animate-ping opacity-50 " style={`background: inherit`}></div>}
              </div>
            </div>

            <!-- Card -->
            <div class={`w-full md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8'}`}>
              <div class="bg-card border border-slate-800 rounded-2xl p-6 hover:border-slate-600 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                <!-- Header -->
                <div class="flex items-start justify-between gap-4 mb-3">
                  <div>
                    <h3 class="font-bold text-white text-lg group-hover:text-primary transition-colors">{exp.role}</h3>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class={`font-semibold text-sm bg-gradient-to-r ${exp.color} bg-clip-text text-transparent`}>{exp.company}</span>
                      {exp.website && (
                        <a
                          href={exp.website}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-slate-600 hover:text-slate-300 transition-colors"
                          title={`Visit ${exp.company}`}
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                          </svg>
                        </a>
                      )}
                    </div>
                  </div>
                  {exp.current && (
                    <span class="flex-shrink-0 text-xs font-mono px-2.5 py-1 rounded-full bg-green-500/10 text-green-400 border border-green-500/20">
                      Current
                    </span>
                  )}
                </div>

                <!-- Meta -->
                <div class="flex flex-wrap gap-3 text-xs text-slate-500 mb-4">
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    {exp.period}
                  </span>
                  <span class="text-slate-700">·</span>
                  <span>{exp.duration}</span>
                  <span class="text-slate-700">·</span>
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    {exp.location}
                  </span>
                </div>

                <p class="text-slate-400 text-sm leading-relaxed mb-4">{exp.description}</p>

                <!-- Stack badges -->
                <div class="flex flex-wrap gap-2">
                  {exp.stack.split(' · ').map(tech => (
                    <span class="text-xs font-mono px-2 py-1 rounded-md bg-slate-800/80 text-slate-400 border border-slate-700/50">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
