---
---
<section id="about" class="py-24 px-6 relative">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="font-mono text-primary text-sm tracking-widest uppercase">01. About</span>
      <h2 class="text-3xl md:text-4xl font-bold mt-2 text-white">Who am I?</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Avatar -->
      <div class="flex justify-center reveal">
        <div class="relative w-64 h-80">
          <!-- Gradient ring -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary via-secondary to-accent p-0.5">
            <div class="w-full h-full rounded-2xl overflow-hidden">
              <img
                src="/photo.jpeg"
                alt="Rakotonarivo Sandratra"
                class="w-full h-full object-cover object-top"
              />
            </div>
          </div>
          <!-- Floating badges -->
          <div class="absolute -top-4 -right-4 bg-primary/90 text-white text-xs font-mono px-3 py-1.5 rounded-full shadow-lg">
            8+ yrs exp.
          </div>
          <div class="absolute -bottom-4 -left-4 bg-secondary/90 text-white text-xs font-mono px-3 py-1.5 rounded-full shadow-lg">
            Frontend Expert
          </div>
        </div>
      </div>

      <!-- Text content -->
      <div class="reveal space-y-6">
        <p class="text-slate-300 text-lg leading-relaxed">
          I am a passionate <span class="text-primary font-semibold">Frontend expert</span>
          based in <span class="text-white font-medium">Antananarivo, Madagascar</span>. With over 8 years of experience,
          I craft pixel-perfect, high-performance interfaces and build full-stack applications end to end.
        </p>
        <p class="text-slate-400 leading-relaxed">
          I actively integrate <span class="text-secondary font-medium">AI tools</span> into my workflow — from code generation to intelligent features — to deliver smarter solutions faster.
          I thrive in agile environments, combining deep technical expertise with a constant drive for innovation.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 pt-4">
          <div class="bg-card rounded-xl p-4 border border-slate-800 text-center hover:border-primary/50 transition-colors">
            <div class="text-2xl font-bold bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">8+</div>
            <div class="text-slate-500 text-sm mt-1">Years exp.</div>
          </div>
          <div class="bg-card rounded-xl p-4 border border-slate-800 text-center hover:border-secondary/50 transition-colors">
            <div class="text-2xl font-bold bg-gradient-to-r from-secondary to-accent bg-clip-text text-transparent">10+</div>
            <div class="text-slate-500 text-sm mt-1">Companies</div>
          </div>
          <div class="bg-card rounded-xl p-4 border border-slate-800 text-center hover:border-accent/50 transition-colors">
            <div class="text-2xl font-bold bg-gradient-to-r from-accent to-primary bg-clip-text text-transparent">10+</div>
            <div class="text-slate-500 text-sm mt-1">Technologies</div>
          </div>
        </div>

        <!-- Links -->
        <div class="flex gap-4 pt-2">
          <a
            href="mailto:syraxrakotonarivo@gmail.com"
            class="flex items-center gap-2 text-slate-400 hover:text-primary transition-colors text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            syraxrakotonarivo@gmail.com
          </a>
          <a
            href="https://www.linkedin.com/in/rakotonarivo-sandratra-72b24a173"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-slate-400 hover:text-primary transition-colors text-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
